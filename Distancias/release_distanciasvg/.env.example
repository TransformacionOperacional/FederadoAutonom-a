# ============================================================================
# PLANTILLA: Credenciales y Configuración
# ============================================================================
# Copiar este archivo a .env y completar con credenciales reales
# Notas:
# - Este archivo NO debe ser commiteado al repositorio
# - Usar archivo .env.example SOLO como referencia
# - Cadenas de conexión deben adaptarse a tu entorno
# ============================================================================

# TERADATA - Conexión a base de datos fuente
TERADATA_DRIVER=Teradata Database ODBC Driver 20.00
TERADATA_HOST=teradata.suranet.com
TERADATA_USER=tu_usuario_teradata
TERADATA_PASSWORD=tu_password_teradata

# SQL SERVER - Conexión a base de datos destino
SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server
SQLSERVER_HOST=surapilotos.database.windows.net
SQLSERVER_DATABASE=SuraPilotos
SQLSERVER_USER=tu_usuario_sqlserver
SQLSERVER_PASSWORD=tu_password_sqlserver

# CONFIGURACIÓN DEL PROYECTO
TABLE_NAME=dbo.DistanciasVG

# FILTROS DE NEGOCIO (modifica según necesidades)
# - RAMO_ID: ID del ramo de seguros (274 = Vida)
# - CANAL_COMERCIAL_IDS: IDs de canales (comma-separated)
RAMO_ID=274
CANAL_COMERCIAL_IDS=24390648,24390649

# MES DE CÁLCULO (formato YYYYMM)
MES_CALCULO=202512
